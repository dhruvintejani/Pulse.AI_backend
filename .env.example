APP_NAME=Pulse AI API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pulse_ai
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
SKIP_DATABASE_INIT=false

BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BACKEND_CORS_ALLOW_CREDENTIALS=true
BACKEND_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
BACKEND_CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID,X-CSRF-Token
BACKEND_CORS_EXPOSE_HEADERS=X-Request-ID,X-Process-Time-Ms

CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://localhost:3000
CLERK_JWKS_CACHE_SECONDS=300
CLERK_SECRET_KEY=
CLERK_API_BASE_URL=https://api.clerk.com/v1

ADMIN_EMAILS=admin@example.com
ADMIN_CLERK_USER_IDS=

INTERNAL_JWT_SECRET=change-this-in-production
INTERNAL_JWT_ALGORITHM=HS256
INTERNAL_JWT_EXPIRES_MINUTES=15

RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_HEALTH=60/minute
RATE_LIMIT_STORAGE_URI=memory://

SECURITY_ALLOWED_HOSTS=*
SECURITY_HEADERS_ENABLED=true
SECURITY_ENABLE_HSTS=false
SECURITY_HSTS_MAX_AGE_SECONDS=31536000
SECURITY_CONTENT_SECURITY_POLICY=default-src 'self'; frame-ancestors 'none'; base-uri 'self'
SECURITY_MAX_REQUEST_SIZE_BYTES=2097152
SECURITY_INPUT_SANITIZATION_ENABLED=true
SECURITY_BLOCK_SUSPICIOUS_INPUT=true

DOCUMENT_STORAGE_PROVIDER=metadata
DOCUMENT_MAX_UPLOAD_SIZE_MB=25
DOCUMENT_PREVIEW_MAX_CHARS=5000
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=pulse-ai/documents

AI_DEFAULT_PROVIDER=mock
AI_ENABLED_PROVIDERS=mock,openai,gemini,claude,groq,deepseek
AI_DEFAULT_MODEL=pulse-ai-default
AI_STREAM_PLACEHOLDER_DELAY_MS=35
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

LOG_LEVEL=INFO
LOG_JSON=false
LOG_DIR=logs
LOG_ROTATION=50 MB
LOG_RETENTION=30 days
LOG_COMPRESSION=zip
LOG_PERFORMANCE_THRESHOLD_MS=1000
